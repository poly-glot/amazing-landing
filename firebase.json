{
  "hosting": {
    "site": "amazing-landing",
    "public": "frontend/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "redirects": [
      { "source": "/", "destination": "/2026/desktop/", "type": 302 }
    ],
    "rewrites": [
      { "source": "/api/**", "run": { "serviceId": "amazing-landing-api", "region": "europe-west2" } },
      { "source": "/admin", "run": { "serviceId": "amazing-landing-api", "region": "europe-west2" } },
      { "source": "/admin/**", "run": { "serviceId": "amazing-landing-api", "region": "europe-west2" } },
      { "source": "/login", "run": { "serviceId": "amazing-landing-api", "region": "europe-west2" } },
      { "source": "/logout", "run": { "serviceId": "amazing-landing-api", "region": "europe-west2" } },
      { "source": "/change-password", "run": { "serviceId": "amazing-landing-api", "region": "europe-west2" } },
      { "source": "/health", "run": { "serviceId": "amazing-landing-api", "region": "europe-west2" } }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
        ]
      }
    ]
  },
  "emulators": {
    "firestore": { "port": 8081, "host": "0.0.0.0" },
    "ui": { "enabled": true, "port": 4000, "host": "0.0.0.0" },
    "singleProjectMode": true
  }
}
