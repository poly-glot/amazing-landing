{
  "name": "azadi-skincare-quiz",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint 2026/",
    "format": "prettier --write '2026/**/*.{js,css,html}'",
    "format:check": "prettier --check '2026/**/*.{js,css,html}'",
    "test": "npx playwright test",
    "test:2026": "npx playwright test --project=2026-desktop --project=2026-mobile",
    "test:2015": "npx playwright test --project=2015-desktop --project=2015-mobile",
    "test:update-snapshots": "npx playwright test --update-snapshots"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.59.1",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "purgecss": "^8.0.0",
    "sass": "^1.99.0",
    "vite": "^6.4.1"
  }
}
